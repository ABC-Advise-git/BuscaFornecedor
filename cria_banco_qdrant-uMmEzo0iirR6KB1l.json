{"updatedAt":"2026-03-05T13:11:30.395Z","createdAt":"2026-03-04T21:43:20.167Z","id":"uMmEzo0iirR6KB1l","name":"cria_banco_qdrant","active":false,"isArchived":false,"nodes":[{"parameters":{},"type":"n8n-nodes-base.manualTrigger","typeVersion":1,"position":[-336,0],"id":"f6b6d6e7-72e9-4222-a087-dfb449cc0ff5","name":"When clicking ‘Execute workflow’"},{"parameters":{"operation":"executeQuery","query":"WITH tokens_por_perfil AS (\n  SELECT sc.cnpj_basico,\n         SUM(sc.token_count) AS total_tokens\n  FROM \"busca_fornecedor\".\"scraped_chunks\" sc\n  WHERE sc.perfil_processado = true\n  GROUP BY sc.cnpj_basico\n), top_perfis AS (\n  SELECT cnpj_basico, total_tokens\n  FROM tokens_por_perfil\n  ORDER BY total_tokens DESC\n  LIMIT 2000\n)\nSELECT cp.id AS company_profile_id\nFROM top_perfis tp\nLEFT JOIN \"busca_fornecedor\".\"company_profile\" cp\n  ON cp.cnpj = tp.cnpj_basico;","options":{}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[-128,0],"id":"1fc2fdbe-4dc9-4f29-8b40-6ecd54887659","name":"Execute a SQL query","credentials":{"postgres":{"id":"8MXZ6U3UVpvutTEe","name":"Supabase"}}},{"parameters":{"batchSize":10,"options":{}},"type":"n8n-nodes-base.splitInBatches","typeVersion":3,"position":[96,0],"id":"041d28fd-b0fe-4828-a8c2-11fc7ee472e3","name":"Loop Over Items"},{"parameters":{"workflowId":{"__rl":true,"value":"TDYKmKr4o7CWOfuE","mode":"list","cachedResultUrl":"/workflow/TDYKmKr4o7CWOfuE","cachedResultName":"Qdrant_MVP"},"workflowInputs":{"mappingMode":"defineBelow","value":{},"matchingColumns":[],"schema":[],"attemptToConvertTypes":false,"convertFieldsToString":true},"options":{"waitForSubWorkflow":false}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.3,"position":[384,64],"id":"c785a11e-fe7d-49e4-b946-6942a9b50f12","name":"Call 'Qdrant_MVP'"},{"parameters":{"amount":1},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[592,64],"id":"6ca933b9-86ee-4049-b1b3-9936fb59df2d","name":"Wait","webhookId":"91c71480-ef41-4996-bb63-73