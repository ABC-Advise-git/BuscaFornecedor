umber }}@s.whatsapp.net"},"type":"n8n-nodes-base.redis","typeVersion":1,"position":[1472,-608],"id":"2aadd05b-8afa-4e28-ba17-c71e5d2a3fee","name":"Desaloca-Memoria","credentials":{"redis":{"id":"WagOtbeuP5fEIhyd","name":"Redis-railway-separado"}}},{"parameters":{"operation":"push","list":"=553599195960@s.whatsapp.net","messageData":"=Agent:{{ $json.data.message.conversation }}"},"type":"n8n-nodes-base.redis","typeVersion":1,"position":[640,-800],"id":"c1ff7a87-5e88-49da-92c0-787013a333ec","name":"Insere-Memoria","credentials":{"redis":{"id":"WagOtbeuP5fEIhyd","name":"Redis-railway-separado"}}},{"parameters":{"workflowInputs":{"values":[{"name":"Message"},{"name":"Number"},{"name":"Name"}]}},"type":"n8n-nodes-base.executeWorkflowTrigger","typeVersion":1.1,"position":[-896,-608],"id":"7b04e459-c4ac-4bb4-8280-8e37c11b9300","name":"Trigger"},{"parameters":{"operation":"get","key":"={{ $json.Number }}@s.whatsapp.net","options":{}},"type":"n8n-nodes-base.redis","typeVersion":1,"position":[-704,-608],"id":"875fb3cc-d819-4084-9518-db47e5b86c74","name":"get-historico","credentials":{"redis":{"id":"WagOtbeuP5fEIhyd","name":"Redis-railway-separado"}}},{"parameters":{"assignments":{"assignments":[{"id":"acf6c088-d876-41bb-9896-7f44d445087b","name":"propertyName","value":"={{ $json.propertyName.reverse() }}","type":"array"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[-496,-608],"id":"68d8623b-4efb-4cfc-86f9-7486e8b0e4fa","name":"reverse-historico"},{"parameters":{"promptType":"define","text":"=historico_conversa: {{ $json.propertyName }}\n","options":{"systemMessage":"# Prompt Refinado: Assistente de Busca de Fornecedores\n\n## Persona e Contexto\nVocê é o assistente inteligente da plataforma **Busca Fornecedor**, operando via WhatsApp. Sua missão é converter diálogos informais em buscas semânticas precisas. Você deve ser direto, prestativo e focado em um único objetivo: **gerar uma query de busca válida**.\n\n## Fluxo de Decisão (Chain-of-Thought)\nAntes de responder, avalie o input do usuário seguindo estes passos:\n1.  **O usuário quer buscar algo?** Se for ofensivo ou recusar o serviço, use `encerrar_conversa`.\n2.  **A informação é suficiente?** Um produto/serviço isolado é insuficiente. Preciso de contexto (ex: finalidade, tipo, volume). Se incompleto, use `prosseguir_conversa`.\n3.  **A query está madura?** Se o usuário forneceu \"O que\" e \"Para que\", use `iniciar_busca` e otimize a query.\n\n## Regras Operacionais\n\n### 1. Definição de Saída (JSON Estrito)\nToda e qualquer resposta deve ser exclusivamente um objeto JSON, sem texto explicativo fora dele:\n```json\n{\n  \"output\": \"prosseguir_conversa | iniciar_busca | encerrar_conversa\",\n  \"mensagem\": \"string (máximo 3 frases)\",\n  \"query\": \"string ou null\"\n}\n```\n\n### 2. Estados do Output\n* **`prosseguir_conversa`**: Use para coletar o que falta. Seja objetivo. \n    * *Critério:* Falta o nome do produto ou a intenção de uso.\n* **`iniciar_busca`**: Use quando houver um produto + contexto.\n    * *Ação:* Otimize a query para termos B2B (ex: de \"camisa pra vender\" para \"fornecedor de camisetas atacado para revenda\").\n    * *Mensagem Padrão:* \"Encontrei fornecedores com base no que você pediu 👍 ✅ Criei uma conta provisória para você acessar todos os resultados. Acesse agora: [https://buscafornecedor.com.br/](https://buscafornecedor.com.br/)\".\n* **`encerrar_conversa`**: Use para spam, ofensas ou quando o usuário explicitamente desistir.\n\n### 3. Qualidade da Query\nUma query válida **precisa** de um substantivo (produto) e um qualificador (contexto).\n* **Inválida:** \"quero comprar\", \"me ajuda\", \"caderno\".\n* **Válida:** \"distribuidor de cadernos escolares atacado\", \"fábrica de embalagens para delivery\", \"serviço de usinagem de peças em aço\".\n\n---\n\n## Exemplos de Comportamento (Few-Shot)\n\n**Entrada:** \"Olá\"\n**Saída:**\n```json\n{\n  \"output\": \"prosseguir_conversa\",\n  \"mensagem\": \"Olá! 👋 Me diga o que você precisa encontrar que eu busco os melhores fornecedores para você agora.\",\n  \"query\": null\n}\n```\n\n**Entrada:** \"Preciso de roupas\"\n**Saída:**\n```json\n{\n  \"output\": \"prosseguir_conversa\",\n  \"mensagem\": \"Entendi. Que tipo de roupas você procura e qual a finalidade? (ex: moda feminina para revenda, uniformes profissionais)\",\n  \"query\": null\n}\n```\n\n**Entrada:** \"Quero fornecedor de marmitas congeladas para minha empresa\"\n**Saída:**\n```json\n{\n  \"output\": \"iniciar_busca\",\n  \"mensagem\": \"Encontrarei fornecedores com base no que você pediu 👍 ✅ Criei uma conta provisória para você acessar todos os resultados. Acesse agora: https://buscafornecedor.com.br/\",\n  \"query\": \"fornecedores de marmitas congeladas para empresas e eventos\"\n}\n```\n\n**Entrada:** \"Não quero nada, só testando\"\n**Saída:**\n```json\n{\n  \"output\": \"encerrar_conversa\",\n  \"mensagem\": \"Sem problemas! Caso precise encontrar fornecedores no futuro, é só me chamar. Até logo! 👍\",\n  \"query\": null\n}\n```\n\n## Restrições Finais\n1.  **Nunca** invente nomes de empresas.\n2.  **Nunca** saia do formato JSON.\n3.  **Máximo** de 3 frases na `mensagem`.\n4.  **Tom de voz:** Profissional, ágil e amigável (estilo WhatsApp)."}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":3.1,"position":[-304,-608],"id":"a6dea3a8-95ac-41be-a29d-4e7b27e0c02a","name":"manager"},{"parameters":{"assignments":{"assignments":[{"id":"fcda94d8-5d7c-47f7-82f6-111b3cff41e1","name":"output","value":"={{ $json.output }}","type":"object"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[0,-608],"id":"90b265a8-69fd-4a52-8146-898cd6b1d02c","name":"set_output"},{"parameters":{"content":"## Trigger de mensagem.\n- Ativa ao receber uma mensagem direta e busca todo o histórico daquele usuário.","height":256,"width":608,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-960,-704],"id":"190aa55f-0504-48d3-81c7-a1726df38551","name":"Sticky Note"},{"parameters":{"content":"## Manager\n- Recebe o histórico e guia a conversa para uma busca ou encerramento.","height":416,"width":640,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-336,-704],"id":"7baec478-eb5a-4752-9862-6e65bd19dd80","name":"Sticky Note1"},{"parameters":{"content":"## Fluxo de Conversa\n- Prosseguir: Continua a conversa, normalmente busca reunir mais informação para realizar a busca.\n- Encerrar: Encerra a conversa e desaloca a memória, ocorre caso o usuário se desvie do objetivo de realizar a busca.\n- Buscar: Cria uma conta provisória, realiza a busca e retorna um resultado limitado. O objetivo é convidar o usuário a acessar o resultado completo no site.","height":720,"width":1344,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[320,-960],"id":"4c4ec09f-fb56-4563-8424-9ad96401ec9e","name":"Sticky Note2"},{"parameters":{"jsCode":"const data = items[0].json;\n\n// 🔹 Nome\nconst nomeUsuario = data.nome || \"\";\n\n// 🔹 Contexto\nconst contexto = data.contexto || \"\";\n\n// 🔹 Resultados\nconst resultados = data.resultados || [];\n\n// 🔹 Magic Link\nconst magic_link = data.magic_link || \"\";\n\n// 🔹 Número\nconst numero = data.telefone || data.numero;\n\n// 🔹 Ordenação\nconst ordenados = resultados.sort((a, b) => b.item.nota - a.item.nota);\n\n// 🔹 Top 2\nconst top2 = ordenados.slice(0, 2);\n\n// 🔹 Telefone simples\nconst formatarTelefone = (tel) => {\n  if (!tel) return \"\";\n  const partes = tel.replace(/[()]/g, \"\").split(\" \");\n  return partes.slice(0, 2).join(\" \");\n};\n\n// 🔹 Limpar site\nconst limparSite = (url) => {\n  if (!url) return \"\";\n  return url\n    .replace(\"https://\", \"\")\n    .replace(\"http://\", \"\")\n    .replace(\"www.\", \"\")\n    .replace(/\\/$/, \"\");\n};\n\n// 🔹 Montar fornecedores (linha única)\nconst fornecedoresTexto = top2.map(f => {\n  const item = f.item;\n\n  const nome = item.razao_social;\n  const site = limparSite(item.site);\n  const telefone = formatarTelefone(item.telefone);\n\n  let extra = \"\";\n\n  if (site) extra += site;\n  if (telefone) extra += (extra ? \", \" : \"\") + telefone;\n\n  return `${nome} (${extra})`;\n});\n\nconst fornecedoresFinal = fornecedoresTexto.join(\" e \");\n\n// 🔹 Mensagem\nlet mensagem = \"\";\n\n// Saudação\nmensagem += nomeUsuario\n  ? `Oi, ${nomeUsuario}, tudo bem?\\n\\n`\n  : `Oi, tudo bem?\\n\\n`;\n\n// Contexto\nif (contexto) {\n  mensagem += `Vi sua mensagem no grupo sobre ${contexto} e puxei dois fornecedores que podem te ajudar nisso:\\n\\n`;\n} else {\n  mensagem += `Vi sua mensagem no grupo e puxei dois fornecedores que podem te ajudar:\\n\\n`;\n}\n\n// Lista\nmensagem += `${fornecedoresFinal}.\\n\\n`;\n\n// CTA com magic link (natural)\nmensagem += `Se quiser ver mais fornecedores, já deixei tudo pronto pra você aqui \\n\\n`;\nmensagem += `${magic_link}\\n\\n`;\nmensagem += `Esse acesso já entra direto com seu número, sem precisar criar conta do zero.`;\n\n// 🔹 Retorno\nreturn [\n  {\n    json: {\n      number: numero,\n      text: mensagem\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1056,-416],"id":"8387c279-b93e-4787-9b71-f813e555bdca","name":"Code in JavaScript"},{"parameters":{"assignments":{"assignments":[{"id":"1b92ef57-85ad-4d6e-b3b2-09b80ecf1c4f","name":"contexto","value":"={{ $json.parametros.descricao }}","type":"string"},{"id":"ef3eecf5-5b46-460f-b04e-d30bd1b6797c","name":"nome","value":"={{ $('Trigger').item.json.Name }}","type":"string"},{"id":"db904fe9-ac62-47d3-a31c-1a9c0e75a16e","name":"resultados","value":"={{ $json.resultados }}","type":"array"},{"id":"d3b04b7e-0057-4a4b-be10-ecea3cdbf61d","name":"magic_link","value":"={{ $('Call \\'Registrar Conta Whatsapp\\'').item.json.magic_link }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[848,-416],"id":"666ff429-dd37-4bed-8347-61084d834bf8","name":"Edit Fields2"},{"parameters":{"resource":"messages-api","ins