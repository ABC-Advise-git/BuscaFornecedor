i-buscafornecedor.up.railway.app/search?debug=1","sendBody":true,"specifyBody":"json","jsonBody":"={\n  \"vectors\": {\n    \"servico\":[{{ $json.servico }}],\n    \"produto\":[{{ $json.produto }}],\n    \"descricao\":[{{ $json.descricao }}],\n    \"publico\":[{{ $json.publico }}],\n    \"cliente\":[{{ $json.cliente }}]\n  },\n  \"weights\": {\n    \"servico\": {{ $json.output.peso_servicos }},\n    \"descricao\": {{ $json.output.peso_descricao }},\n    \"publico\": {{ $json.output.peso_publico }},\n    \"cliente\": {{ $json.output.peso_clientes }},\n    \"produto\": {{ $json.output.peso_produtos }},\n    \"bm25\": {{ $json.output.peso_bm25 }}\n\n  },\n  \"filter\": {\n    \"modelo_negocio\": \"\",\n    \"cidade\":\"{{ $('set_data_busca').item.json.lista_municipio || \" \" }}\",\n    \"uf\":\"{{ $('set_data_busca').item.json.ufs_selecionadas || \" \" }}\"\n  },\n  \"filter_not\": {\n    \"descricao\": \"\"\n  },\n  \"limit_per_vector\": 10,\n  \"final_limit\": 20,\n  \"bm25_query\": \"{{ $json.bm25\n  .replace(/[^\\w\\s\\-.,]/g, '')\n  .replace(/\\s+/g, ' ')\n  .trim()\n}}\"\n}","options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.4,"position":[-2496,-1712],"id":"48f09c9b-6c93-4f8b-b260-957aa3a07cd4","name":"Busca_Vetorial"},{"parameters":{"jsCode":"function safe(v) {\n  if (v === null || v === undefined) return \"\";\n  return String(v);\n}\n\n// 1. Ordenar resultados pelo score final (descendente)\nconst sorted = [...items].sort(\n  (a, b) => (b.json.score_final || 0) - (a.json.score_final || 0)\n);\n\n// 2. Identificar os extremos para a normalização (Min-Max)\nconst maxScore = sorted[0]?.json?.score_final || 0;\nconst minScore = sorted[sorted.length - 1]?.json?.score_final || 0;\n\nreturn sorted.map(item => {\n  const j = item.json;\n  const payload = j.payload || {};\n  const score = j.score_final || 0;\n\n  let nota = 75; // Piso padrão\n\n  // 3. Lógica de Interpolação Linear para o intervalo [75, 100]\n  if (maxScore > minScore) {\n    // Cálculo: Base 75 + Proporção do Score (0 a 25)\n    nota = 75 + (25 * (score - minScore)) / (maxScore - minScore);\n  } else if (maxScore > 0) {\n    // Se todos os scores forem iguais, todos recebem a nota máxima\n    nota = 100;\n  }\n\n  // 4. Conversão para INTEIRO e trava de segurança\n  nota = Math.round(nota); \n  nota = Math.max(75, Math.min(100, nota));\n\n  return {\n    json: {\n      id: j.id || null,\n      score_final: score,\n      nota: parseInt(nota), // Garante que o output seja um Number Inteiro\n\n      cnpj: safe(payload.cnpj),\n      n_exibicoes: j.n_exibicoes || 0,\n      plano_categoria: j.plano_categoria || null,\n\n      full_profile: {\n        identidade: {\n          nome_empresa: safe(payload.nome_empresa)\n        },\n        contato: {\n          url_site: safe(payload.site),\n          telefones: safe(payload.telefone),\n          emails: safe(payload.email)\n        }\n      }\n    }\n  };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-2080,-1712],"id":"09d80811-3585-410a-9cc4-4910890a172a","name":"Process_Profile"},{"parameters":{"content":"## Em caso de poucos resultados chama o cenário de fallback","height":320,"width":512,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-816,-1840],"id":"4e08c0a9-75bf-4e84-a97f-5837687b91be","name":"Sticky Note26"}],"connections":{"Webhook":{"main":[[{"node":"tipo_busca1","type":"main","index":0}]]},"get_result":{"main":[[{"node":"Mostra resultado intermediário1","type":"main","index":0}]]},"set_result":{"main":[[{"node":"Aggregate2","type":"main","index":0}]]},"Aggregate2":{"main":[[{"node":"get_result","type":"main","index":0}]]},"tipo_busca1":{"main":[[{"node":"Merge","type":"main","index":0}],[{"node":"acha_cidade1","type":"main","index":0}]]},"Split Out3":{"main":[[{"node":"Limit","type":"main","index":0}]]},"Aggregate3":{"main":[[{"node":"Merge6","type":"main","index":0}]]},"lista_cidades1":{"main":[[{"node":"Get_codes1","type":"main","index":0}]]},"Get