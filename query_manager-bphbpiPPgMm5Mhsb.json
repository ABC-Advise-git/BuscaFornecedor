sition":[928,-464],"id":"f9084f5a-2dd6-4b4f-b76f-5cc12cf2c2bb","name":"Edit Fields32"},{"parameters":{"mode":"combine","combineBy":"combineByPosition","numberInputs":5,"options":{}},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1216,-128],"id":"fe4581c6-9a5d-4bcf-b73c-24f90b628e76","name":"Merge4"},{"parameters":{"jsonSchemaExample":"{\n\"query_original\": \"string\",\n\n\"produtos\": \"string\",\n\"servicos\": \"string\",\n\"descricao\": \"string\",\n\"publico\": \"string\",\n\"clientes\": \"string\",\n\"bm25\": \"string\",\n\n\"peso_produtos\": 0.0,\n\"peso_servicos\": 0.0,\n\"peso_descricao\": 0.0,\n\"peso_publico\": 0.0,\n\"peso_clientes\": 0.0,\n\"peso_bm25\": 0.0,\n\n\"Modelo_Negocio\": \"string\"\n}","autoFix":true},"type":"@n8n/n8n-nodes-langchain.outputParserStructured","typeVersion":1.3,"position":[64,128],"id":"4ba57fbc-78c2-4b42-99d1-a486c32d5b0f","name":"Structured Output Parser"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-5-mini"},"builtInTools":{},"options":{"maxRetries":5}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.3,"position":[-16,288],"id":"d3fa70a2-3e80-4df6-960f-94fc8d48a8a6","name":"OpenAI Chat Model5","credentials":{"openAiApi":{"id":"g2eqCZ5ZlxiAjjhU","name":"OpenAi account"}}},{"parameters":{"modelName":"models/gemini-3-flash-preview","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[-128,128],"id":"8a0630b9-d993-4ead-bec7-37d853ab0d5a","name":"Google Gemini Chat Model1","credentials":{"googlePalmApi":{"id":"NFDJdyFl82zPlGi4","name":"Google Gemini(PaLM) Api account"}}},{"parameters":{"promptType":"define","text":"=consulta_usuário: {{ $json.consulta }}","hasOutputParser":true,"options":{"systemMessage":"=ROLE\nEspecialista em Engenharia de Busca B2B e Hybrid Retrieval. Sua missão é garantir que o objeto real da busca (o substantivo) seja o filtro dominante, impedindo que vizinhos semânticos irrelevantes dominem o resultado.\n\nOBJETIVO\nTransformar consultas em JSON estruturado para busca híbrida, utilizando o BM25 como um \"validador de nicho\" e o vetor denso ancorado ao objeto.\n\nTAREFA: DISTRIBUIÇÃO DE PESOS (REGRA OBRIGATÓRIA)\nA soma total deve ser sempre 1.0.\n\nNúcleo (Produto + Serviço): Soma de peso_produtos + peso_servicos = 0.60.\n\nAncoragem Obrigatória: O substantivo principal deve aparecer em todos os termos.\n\nPrecisão Lexical (BM25): O peso_bm25 deve ser SEMPRE 0.20.\n\nContexto (Descrição): O peso_descricao deve ser SEMPRE 0.15.\n\nRestante (Público + Clientes): Soma de peso_publico + peso_clientes = 0.05. (Sugestão: 0.02 e 0.03).\n\nDIRETRIZES DE CONTEÚDO (REGRAS ANTI-ERRO)\nAncoragem de Objeto (Vetor Denso): Nos campos produtos e servicos, o objeto principal deve estar presente em cada termo gerado.\n\nExemplo Ruim: \"Higienização técnica\", \"Injeção\".\n\nExemplo Correto: \"Higienização de Big Bags\", \"Injeção de Bancos Plásticos\".\n\nBM25 - Filtro de Substantivo: O campo bm25 deve conter EXCLUSIVAMENTE substantivos concretos, siglas e sinônimos diretos do objeto.\n\nPROIBIDO: Incluir verbos (limpeza, fabricação, manutenção) ou adjetivos genéricos (industrial, técnico, rápido).\n\nObjetivo: Se a busca é \"higienização de bag\", o BM25 deve ser: bag, bags, bigbag, ráfia, contentor.\n\nFoco no Produto Acabado: Se o usuário busca um objeto, evite termos de matéria-prima isolada (ex: use \"banco de polipropileno\" em vez de apenas \"polipropileno\") para não atrair fornecedores de resina.\n\nSanitização: Remova saudações, pedidos de orçamento (\"cotação\", \"preço\") e termos de teste.\n\nREGRAS DE NEGÓCIO\nModelo_Negocio: Selecione EXATAMENTE um: [Fabricante, Distribuidor, Atacado, Varejo, Prestador de Serviço].\n\nPROIBIDO: Explicar, conversar ou usar markdown fora do bloco JSON. Retorne APENAS o JSON.\n\nSCHEMA DE SAÍDA\n{\n\"query_original\": \"string\",\n\"produtos\": \"Objeto + Atributo (max 4 termos)\",\n\"servicos\": \"Ação + Objeto Específico (max 4 termos)\",\n\"descricao\": \"string\",\n\"publico\": \"string\",\n\"clientes\": \"string\",\n\"bm25\": \"apenas substantivos e siglas (sem verbos)\",\n\"peso_produtos\": 0.0,\n\"peso_servicos\": 0.0,\n\"peso_descricao\": 0.15,\n\"peso_publico\": 0.02,\n\"peso_clientes\": 0.03,\n\"peso_bm25\": 0.20,\n\"Modelo_Negocio\": \"string\"\n}\n\nExemplo Output Esperado:\nJSON\n{\n\"query_original\": \"higienização de big bag açucar\",\n\"produtos\": \"big bag, contentor flexível, bags de ráfia, embalagem FIBC\",\n\"servicos\": \"higienização de big bags, lavagem de bags alimentícios, sanitização de bigbags, recuperação de contentores de ráfia\",\n\"descricao\": \"Serviços especializados de limpeza, lavagem técnica e descontaminação de big bags e embalagens industriais para o setor alimentício.\",\n\"publico\": \"indústria de açúcar, usinas sucroalcooleiras, logística de granéis\",\n\"clientes\": \"compradores de usinas, gerentes de logística, indústrias de alimentos\",\n\"bm25\": \"bag bags bigbag fibc ráfia contentor\",\n\"peso_produtos\": 0.10,\n\"peso_servicos\": 0.50,\n\"peso_descricao\": 0.15,\n\"peso_publico\": 0.02,\n\"peso_clientes\": 0.03,\n\"peso_bm25\": 0.20,\n\"Modelo_Negocio\": \"Prestador de Serviço\"\n}"}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":3.1,"position":[-64,-64],"id":"737f5e4d-79ed-474e-a41a-1bb88c5a24fd","name":"AI Agent2","retryOnFail":true,"maxTries":2,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"39fcde96-b680-4523-8008-93e215198367","name":"servico","value":"={{ $('serviço').item.json.data[0].embedding }}","type":"array"},{"id":"97b533be-644b-4f44-a4dd-325115d41e2b","name":"produto","value":"={{ $('produto').item.json.data[0].embedding }}","type":"array"},{"id":"d032dca8-4dd2-4eaf-b9c8-97a1381e0d60","name":"descricao","value":"={{ $('descricao').item.json.data[0].embedding }}","type":"array"},{"id":"ab79da64-81c5-4166-9ab6-1964fb778930","name":"publico","value":"={{ $('publico').item.json.data[0].embedding }}","type":"a