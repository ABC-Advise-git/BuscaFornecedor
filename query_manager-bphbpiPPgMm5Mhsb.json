sition":[928,-464],"id":"f9084f5a-2dd6-4b4f-b76f-5cc12cf2c2bb","name":"Edit Fields32"},{"parameters":{"mode":"combine","combineBy":"combineByPosition","numberInputs":5,"options":{}},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1216,-128],"id":"fe4581c6-9a5d-4bcf-b73c-24f90b628e76","name":"Merge4"},{"parameters":{"jsonSchemaExample":"{\n\"query_original\": \"string\",\n\n\"produtos\": \"string\",\n\"servicos\": \"string\",\n\"descricao\": \"string\",\n\"publico\": \"string\",\n\"clientes\": \"string\",\n\"bm25\": \"string\",\n\n\"peso_produtos\": 0.0,\n\"peso_servicos\": 0.0,\n\"peso_descricao\": 0.0,\n\"peso_publico\": 0.0,\n\"peso_clientes\": 0.0,\n\"peso_bm25\": 0.0,\n\n\"Modelo_Negocio\": \"string\"\n}","autoFix":true},"type":"@n8n/n8n-nodes-langchain.outputParserStructured","typeVersion":1.3,"position":[64,128],"id":"4ba57fbc-78c2-4b42-99d1-a486c32d5b0f","name":"Structured Output Parser"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-5-mini"},"builtInTools":{},"options":{"maxRetries":5}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.3,"position":[-16,288],"id":"d3fa70a2-3e80-4df6-960f-94fc8d48a8a6","name":"OpenAI Chat Model5","credentials":{"openAiApi":{"id":"g2eqCZ5ZlxiAjjhU","name":"OpenAi account"}}},{"parameters":{"modelName":"models/gemini-3-flash-preview","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[-128,128],"id":"8a0630b9-d993-4ead-bec7-37d853ab0d5a","name":"Google Gemini Chat Model1","credentials":{"googlePalmApi":{"id":"NFDJdyFl82zPlGi4","name":"Google Gemini(PaLM) Api account"}}},{"parameters":{"promptType":"define","text":"=consulta_usuário: {{ $json.consulta }}","hasOutputParser":true,"options":{"systemMessage":"=# ROLE\nEspecialista em Engenharia de Busca B2B e Hybrid Retrieval.\n\n# OBJETIVO\nTransformar consultas em JSON estruturado para busca híbrida, garantindo expansão semântica controlada e aderência matemática rigorosa.\n\n# TAREFA: DISTRIBUIÇÃO DE PESOS (REGRA OBRIGATÓRIA)\nA soma total deve ser sempre 1.0. \n1. **Núcleo (Produto + Serviço):** Soma de `peso_produtos` + `peso_servicos` = **0.65**.\n   - Identifique a predominância (venda de item ou execução de tarefa) e distribua os 0.65.\n2. **Precisão Lexical (BM25):** O `peso_bm25` deve ser SEMPRE **0.25**.\n3. **Contexto (Descrição + Público + Clientes):** Soma de `peso_descricao` + `peso_publico` + `peso_clientes` = **0.10**.\n   - Sugestão: Descrição (0.04), Público (0.03), Clientes (0.03).\n\n# DIRETRIZES DE CONTEÚDO E EXPANSÃO\n1. **Dilation Search (Sem mencionar níveis):** Gere uma expansão de termos começando do ultra-específico para o genérico, mas **MANTENHA O ESCOPO**. Se a busca é \"cortina\", o termo mais genérico deve ser \"decoração de janelas\" ou \"têxteis para interiores\", e NÃO \"mobiliário\" ou \"construção civil\".\n2. **Formatação:** Use APENAS vírgulas para separar termos. PROIBIDO usar barras (|), pontos e vírgula (;) ou prefixos como \"Nível 1:\".\n3. **BM25:** Foque em palavras-chave puras, siglas, marcas e termos técnicos sem conectivos.\n\n# REGRAS DE NEGÓCIO\n- Modelo_Negocio: Selecione EXATAMENTE um: [Fabricante, Distribuidor, Atacado, Varejo, Prestador de Serviço].\n- PROIBIDO: Explicar, conversar ou usar markdown. Retorne APENAS o JSON.\n\n# SCHEMA DE SAÍDA\n{\n  \"query_original\": \"string\",\n  \"produtos\": \"termo1, termo2, termo3, termo4\",\n  \"servicos\": \"termo1, termo2, termo3, termo4\",\n  \"descricao\": \"string\",\n  \"publico\": \"string\",\n  \"clientes\": \"string\",\n  \"bm25\": \"string\",\n  \"peso_produtos\": 0.0,\n  \"peso_servicos\": 0.0,\n  \"peso_descricao\": 0.0,\n  \"peso_publico\": 0.0,\n  \"peso_clientes\": 0.0,\n  \"peso_bm25\": 0.25,\n  \"Modelo_Negocio\": \"string\"\n}\n\n\n# Exemplo Output Esperado:\n\nJSON\n{\n  \"query_original\": \"compra de persianas de leito e persianas de escritório, atendimento todo o Brasil de preferencia\",\n  \"produtos\": \"persianas de leito, persianas de escritório, persiana rolô, persiana blackout, persianas motorizadas, cortinas técnicas, soluções para janelas\",\n  \"servicos\": \"venda de persianas, instalação de persianas, entrega nacional de cortinas, orçamento de persianas sob medida\",\n  \"descricao\": \"Fornecedor de persianas para ambientes residenciais e corporativos com capacidade de entrega e atendimento em território nacional.\",\n  \"publico\": \"escritórios, hospitais, residências, arquitetos, decoradores\",\n  \"clientes\": \"empresas, clínicas, compradores corporativos, proprietários de imóveis\",\n  \"bm25\": \"persiana leito escritório blackout motorizada entrega brasil sob medida\",\n  \"peso_produtos\": 0.55,\n  \"peso_servicos\": 0.10,\n  \"peso_descricao\": 0.04,\n  \"peso_publico\": 0.03,\n  \"peso_clientes\": 0.03,\n  \"peso_bm25\": 0.25,\n  \"Modelo_Negocio\": \"Varejo\"\n}"}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":3.1,"position":[-64,-64],"id":"737f5e4d-79ed-474e-a41a-1bb88c5a24fd","name":"AI Agent2","retryOnFail":true,"maxTries":2,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"39fcde96-b680-4523-8008-93e215198367","name":"servico","value":"={{ $('serviço').item.json.data[0].embedding }}","type":"array"},{"id":"97b533be-644b-4f44-a4dd-325115d41e2b","name":"produto","value":"={{ $('produto').item.json.data[0].embedding }}","type":"array"},{"id":"d032dca8-4dd2-4eaf-b9c8-97a1381e0d60","name":"descricao","value":"={{ $('descricao').item.json.data[0].embedding }}","type":"array"},{"id":"ab79da64-81c5-4166-9ab6-1964fb778930","name":"publico","value":"={{ $('publico').item.json.data[0].embedding }}","type":"array"},{"id":"e2b92a59-3fac-45f9-a241-16ad65a8282e","name":"cliente","value":"={{ $('cliente1').item.json.data[0].embedding }}","type":"array"},{"id":"afd20d86-85db-4fef-83e1-a17968e56c14","name":"bm25","value":"={{ $('set_profile_data1').item.json.output.bm25 }}","type":"string"},{"id":"70923895-78be-4b7e-97d8-40216b58f493","name":"Modelo_Ne