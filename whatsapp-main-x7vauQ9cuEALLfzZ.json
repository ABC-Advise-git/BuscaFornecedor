n;\nconst data = body.data || json.data || {};\nconst key = data.key || json.key || {};\n\n// 🔹 IDs principais\nconst messageId = key.id || data.id || null;\nconst remoteJid = key.remoteJid || \"\";\nconst participant = key.participant || \"\";\n\n// 🔹 Detecta tipo de chat\nlet chatType = \"unknown\";\n\nif (remoteJid.endsWith(\"@g.us\")) {\n  chatType = \"group\";\n} else if (remoteJid.endsWith(\"@s.whatsapp.net\")) {\n  chatType = \"private\";\n}\n\n// 🔹 Fallback (algumas libs não preenchem corretamente)\nif (chatType === \"unknown\") {\n  if (participant) {\n    chatType = \"group\";\n  }\n}\n\n// 🔹 Extrai número do usuário correto\nlet senderJid = null;\n\nif (chatType === \"group\") {\n  senderJid = participant || remoteJid;\n} else {\n  senderJid = remoteJid;\n}\n\n// 🔹 Número limpo\nconst senderNumber = senderJid?.split(\"@\")[0] || null;\n\n// 🔹 Nome do usuário (se existir)\nconst pushName = data.pushName || body.pushName || null;\n\n// 🔹 Timestamp\nconst timestamp = data.messageTimestamp || body.messageTimestamp || null;\n\n// 🔹 Tipo de mensagem\nconst messageType = data.messageType || null;\n\n// 🔹 Conteúdo da mensagem (normalizado)\nlet messageText = null;\n\nif (data.message?.conversation) {\n  messageText = data.message.conversation;\n} else if (data.message?.extendedTextMessage?.text) {\n  messageText = data.message.extendedTextMessage.text;\n} else if (data.message?.imageMessage?.caption) {\n  messageText = data.message.imageMessage.caption;\n} else if (data.message?.videoMessage?.caption) {\n  messageText = data.message.videoMessage.caption;\n}\n\n// 🔹 Info extra útil\nconst instance = body.instance || null;\nconst event = body.event || null;\n\n// 🔹 Retorno estruturado\nreturn [\n  {\n    json: {\n      // 🔑 Identificação\n      messageId,\n      chatId: remoteJid,\n      senderJid,\n      senderNumber,\n      participant,\n\n      // 🧠 Contexto\n      chatType,\n      isGroup: chatType === \"group\",\n      isPrivate: chatType === \"private\",\n\n      // 👤 Usuário\n      pushName,\n\n      // 💬 Mensagem\n      messageType,\n      messageText,\n      timestamp,\n\n      // ⚙️ Sistema\n      instance,\n      event,\n\n      // 🧪 Debug (opcional, pode remover em prod)\n      original: json\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-3664,0],"id":"0fc716d6-73ac-4cc1-80b3-969627149eae","name":"Code in JavaScript"},{"parameters":{"assignments":{"assignments":[{"id":"7d2e608b-1e96-4ea6-b685-de445200cff5","name":"ID","value":"={{ $('Switch1').item.json.senderJid }}","type":"string"},{"id":"4fa27626-25ae-4257-9d54-bff1cb0a6c9f","name":"message","value":"={{ $json.messageText || $json.data}}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[-2208,32],"id":"2d45fbd0-d78e-4b1b-8ded-d59048328098","name":"set_id"},{"parameters":{"operation":"push","list":"={{ $json.ID }}","messageData":"={{ $json.message }}","tail":true},"type":"n8n-nodes-base.redis","typeVersion":1,"position":[-2048,32],"id":"8681d622-04b6-4784-928c-7c5e43f6b7a3","name":"push_on_tail","credentials":{"redis":{"id":"WagOtbeuP5fEIhyd","name":"Redis-railway-separado"}}},{"parameters":{"amount":20},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[-1888,32],"id":"3bceb92c-6d8e-4b50-bcd1-ac95da602500","name":"1minute","webhookId":"266fe8d6-be56-4dc7-b27c-ecab5469ace2"},{"parameters":{"operation":"get","propertyName":"mensagens","key":"={{ $json.ID }}","options":{}},"type":"n8n-nodes-base.redis","typeVersion":1,"position":[-1728,32],"id":"c0018ac3-21f0-4bea-8cfd-138ddaad3aef","name":"get_tail","credentials":{"redis":{"id":"WagOtbeuP5fEIhyd","name":"Redis-railway-separado"}}},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"19f5efd1-06a1-4af5-b0b3-f179b7b50e98","leftValue":"={{ $json.mensagens.last() }}","rightValue":"={{ $('1minute').item.json.message }}","operator":{"type":"string","operation"