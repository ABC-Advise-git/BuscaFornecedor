lse {\n  senderJid = remoteJid;\n}\n\n// 🔹 Número limpo\nconst senderNumber = senderJid?.split(\"@\")[0] || null;\n\n// 🔹 Nome do usuário (se existir)\nconst pushName = data.pushName || body.pushName || null;\n\n// 🔹 Timestamp\nconst timestamp = data.messageTimestamp || body.messageTimestamp || null;\n\n// 🔹 Tipo de mensagem\nconst messageType = data.messageType || null;\n\n// 🔹 Conteúdo da mensagem (normalizado)\nlet messageText = null;\n\nif (data.message?.conversation) {\n  messageText = data.message.conversation;\n} else if (data.message?.extendedTextMessage?.text) {\n  messageText = data.message.extendedTextMessage.text;\n} else if (data.message?.imageMessage?.caption) {\n  messageText = data.message.imageMessage.caption;\n} else if (data.message?.videoMessage?.caption) {\n  messageText = data.message.videoMessage.caption;\n}\n\n// 🔹 Info extra útil\nconst instance = body.instance || null;\nconst event = body.event || null;\n\n// 🔹 Retorno estruturado\nreturn [\n  {\n    json: {\n      // 🔑 Identificação\n      messageId,\n      chatId: remoteJid,\n      senderJid,\n      senderNumber,\n      participant,\n\n      // 🧠 Contexto\n      chatType,\n      isGroup: chatType === \"group\",\n      isPrivate: chatType === \"private\",\n\n      // 👤 Usuário\n      pushName,\n\n      // 💬 Mensagem\n      messageType,\n      messageText,\n      timestamp,\n\n      // ⚙️ Sistema\n      instance,\n      event,\n\n      // 🧪 Debug (opcional, pode remover em prod)\n      original: json\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-3744,0],"id":"0fc716d6-73ac-4cc1-80b3-969627149eae","name":"Code in JavaScript"},{"parameters":{"assignments":{"assignments":[{"id":"7d2e608b-1e96-4ea6-b685-de445200cff5","name":"ID","value":"={{ $('Switch1').item.json.senderJid }}","type":"string"},{"id":"4fa27626-25ae-4257-9d54-bff1cb0a6c9f","name":"message","value":"={{ $json.messageText || $json.data}}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","t