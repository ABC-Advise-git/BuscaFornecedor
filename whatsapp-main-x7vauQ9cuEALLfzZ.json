message?.videoMessage?.caption) {\n  messageText = data.message.videoMessage.caption;\n}\n\n// 🔹 Info extra útil\nconst instance = body.instance || null;\nconst event = body.event || null;\n\n// 🔹 Retorno estruturado\nreturn [\n  {\n    json: {\n      // 🔑 Identificação\n      messageId,\n      chatId: remoteJid,\n      senderJid,\n      senderNumber,\n      participant,\n\n      // 🧠 Contexto\n      chatType,\n      isGroup: chatType === \"group\",\n      isPrivate: chatType === \"private\",\n\n      // 👤 Usuário\n      pushName,\n\n      // 💬 Mensagem\n      messageType,\n      messageText,\n      timestamp,\n\n      // ⚙️ Sistema\n      instance,\n      event,\n\n      // 🧪 Debug (opcional, pode remover em prod)\n      original: json\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-3664,0],"id":"0fc716d6-73ac-4cc1-80b3-969627149eae","name":"Code in JavaScript"},{"parameters":{"assignments":{"assignments":[{"id":"7d2e608b-1e96-4ea6-b685-de445200cff5","name":"ID","value":"={{ $('Switch1').item.json.senderJid }}","type":"string"},{"id":"4fa27626-25ae-4257-9d54-bff1cb0a6c9f","name":"message","value":"={{ $json.messageText || $json.data}}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[-2208,32],"id":"2d45fbd0-d78e-4b1b-8ded-d59048328098","name":"set_id"},{"parameters":{"operation":"push","list":"={{ $json.ID }}","messageData":"={{ $json.message }}","tail":true},"type":"n8n-nodes-base.redis","typeVersion":1,"position":[-2048,32],"id":"8681d622-04b6-4784-928c-7c5e43f6b7a3","name":"push_on_tail","credentials":{"redis":{"id":"WagOtbeuP5fEIhyd","name":"Redis-railway-separado"}}},{"parameters":{"amount":20},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[-1888,32],"id":"3bceb92c-6d8e-4b50-bcd1-ac95da602500","name":"1minute","webhookId":"266fe8d6-be56-4dc7-b27c-ecab5469ace2"},{"parameters":{"operation":"get","propertyName":"mensagens","key":"={{ $json.ID }}","options":{}},"type":"n8n-nodes-bas