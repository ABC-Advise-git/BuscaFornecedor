er,\n      isGroup: chatType === \"group\",\n      isPrivate: chatType === \"private\",\n      \n      // útil para debug\n      original: item.json\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-2704,32],"id":"0fc716d6-73ac-4cc1-80b3-969627149eae","name":"Code in JavaScript"},{"parameters":{"assignments":{"assignments":[{"id":"d560fb3c-d674-4b71-94f4-ba3701ca373b","name":"id","value":"={{ $('MensagemRecebida').item.json.body.message_id }}","type":"string"},{"id":"9541b72c-d90c-4501-95da-fe99008f7a39","name":"chat_id","value":"={{ $('MensagemRecebida').item.json.body.chat_id }}","type":"string"},{"id":"6a249999-bd16-4682-9e28-b0306746ddb8","name":"sender_id","value":"={{ $('MensagemRecebida').item.json.body.sender.attendee_provider_id }}","type":"string"},{"id":"0a2e722d-e172-4e89-b093-e32da40af32a","name":"sender_attendee_id","value":"={{ $('MensagemRecebida').item.json.body.sender.attendee_id }}","type":"string"},{"id":"59959b8a-0071-4427-b3f9-a42377fa7074","name":"account_id","value":"={{ $('MensagemRecebida').item.json.body.account_id }}","type":"string"},{"id":"5141a617-94f8-4d97-91af-7866cc5138f0","name":"provider_id","value":"={{ $('MensagemRecebida').item.json.body.provider_chat_id }}","type":"string"},{"id":"d0d3b90d-3cff-43a7-aa27-d14974871b9f","name":"timestamp","value":"={{ $('MensagemRecebida').item.json.body.timestamp }}","type":"string"},{"id":"86933015-604e-4e3a-ac39-dca1a0f4dcbb","name":"text","value":"={{ $json.mensagens }}","type":"string"},{"id":"4baf29ab-761a-4a4e-bcec-82d8108de6de","name":"message_type","value":"={{ $('MensagemRecebida').item.json.body.message_type }}","type":"string"},{"id":"e6835935-beef-496e-9034-a616446b050b","name":"attendee_type","value":"={{ $('MensagemRecebida').item.json.body.account_type }}","type":"string"},{"id":"116b94f0-925c-4e78-8e6d-e77311e739ac","name":"attachments","value":"={{ $('MensagemRecebida').item.json.body.attachments }}","type":"array"},{"id":"e20d6b63-06cd-4678-8c06-70805