= data.message.conversation;\n} else if (data.message?.extendedTextMessage?.text) {\n  messageText = data.message.extendedTextMessage.text;\n} else if (data.message?.imageMessage?.caption) {\n  messageText = data.message.imageMessage.caption;\n} else if (data.message?.videoMessage?.caption) {\n  messageText = data.message.videoMessage.caption;\n}\n\n// 🔹 Info extra útil\nconst instance = body.instance || null;\nconst event = body.event || null;\n\n// 🔹 Retorno estruturado\nreturn [\n  {\n    json: {\n      // 🔑 Identificação\n      messageId,\n      chatId: remoteJid,\n      senderJid,\n      senderNumber,\n      participant,\n\n      // 🧠 Contexto\n      chatType,\n      isGroup: chatType === \"group\",\n      isPrivate: chatType === \"private\",\n\n      // 👤 Usuário\n      pushName,\n\n      // 💬 Mensagem\n      messageType,\n      messageText,\n      timestamp,\n\n      // ⚙️ Sistema\n      instance,\n      event,\n\n      // 🧪 Debug (opcional, pode remover em prod)\n      original: json\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-2704,32],"id":"0fc716d6-73ac-4cc1-80b3-969627149eae","name":"Code in JavaScript"},{"parameters":{"assignments":{"assignments":[{"id":"d560fb3c-d674-4b71-94f4-ba3701ca373b","name":"id","value":"={{ $('MensagemRecebida').item.json.body.message_id }}","type":"string"},{"id":"9541b72c-d90c-4501-95da-fe99008f7a39","name":"chat_id","value":"={{ $('MensagemRecebida').item.json.body.chat_id }}","type":"string"},{"id":"6a249999-bd16-4682-9e28-b0306746ddb8","name":"sender_id","value":"={{ $('MensagemRecebida').item.json.body.sender.attendee_provider_id }}","type":"string"},{"id":"0a2e722d-e172-4e89-b093-e32da40af32a","name":"sender_attendee_id","value":"={{ $('MensagemRecebida').item.json.body.sender.attendee_id }}","type":"string"},{"id":"59959b8a-0071-4427-b3f9-a42377fa7074","name":"account_id","value":"={{ $('MensagemRecebida').item.json.body.account_id }}","type":"string"},{"id":"5141a617-94f8-4d97-91af-7866cc